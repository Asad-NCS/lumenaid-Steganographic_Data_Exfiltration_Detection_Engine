# LumenAid — Environment Configuration Example
# Copy this file to '.env' and update the values for your local environment.

# --- PostgreSQL Configuration ---
# If your postgres password is NOT '3568', update it here:
PGPASSWORD=3568
LUMENAID_PG_DSN="host=localhost dbname=lumenaid user=postgres password=3568"

# --- MongoDB Configuration ---
LUMENAID_MONGO_URI="mongodb://localhost:27017"
LUMENAID_MONGO_DB="lumenaid"

# --- System Defaults ---
LUMENAID_DEFAULT_USER=1
LUMENAID_UPLOAD_DIR="./temp_uploads"
